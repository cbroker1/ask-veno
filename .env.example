# Copy this to .env for local use.
# Never commit .env.

# YouTube discovery
YOUTUBE_CHANNEL_URL=
TITLE_FILTERS=ONE LIFE,1 LIFE
MAX_DISCOVERY_VIDEOS=50
MAX_NEW_VIDEOS=1

# Local repo data paths
SQLITE_DB_PATH=.state/youtube_ingest.sqlite
YOUTUBE_AUDIO_ROOT=data/raw/youtube
TRANSCRIPT_ROOT=data/transcripts
CHROMA_PATH=data/chroma
REPORTS_ROOT=reports

# Audio-only yt-dlp behavior
AUDIO_FORMAT=mp3
YTDLP_BROWSER=chrome
USE_BROWSER_COOKIES=false
USE_COOKIES_TXT_FALLBACK=false
COOKIES_TXT_PATH=cookies.txt

# Optional yt-dlp advanced JS runtime behavior
YTDLP_USE_DENO=false
YTDLP_DENO_PATH=

# Optional local model helper
OLLAMA_URL=http://localhost:11434
QWEN_MODEL=qwen3.6:latest
QWEN_MAX_TOTAL_CHARS=60000
QWEN_MAX_FILE_CHARS=8000

# Whisper transcription
WHISPER_MODEL=large
WHISPER_DEVICE=cuda:0
WHISPER_WORD_TIMESTAMPS=true
MAX_TRANSCRIBE_VIDEOS=1

# ChromaDB ingestion
CHROMA_COLLECTION=youtube_chunks
EMBED_MODEL_NAME=intfloat/multilingual-e5-large
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=0.25
EMBED_BATCH_SIZE=32
MAX_EMBED_VIDEOS=1

# Inference / retrieval test
RETRIEVAL_TOP_K=8
OLLAMA_MODEL=llama3.2:latest
OLLAMA_SERVER=localhost
OLLAMA_TIMEOUT_SECONDS=300

